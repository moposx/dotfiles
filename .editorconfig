root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.zsh]
shell = zsh
indent_style = space
indent_size = 4
binary_next_line = true
switch_case_indent = true
space_redirects = false
keep_padding = true

[.gitignore]
indent_style = tab
